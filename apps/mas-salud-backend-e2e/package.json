{
  "name": "@mas-salud-backend/mas-salud-backend-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "name": "mas-salud-backend-e2e",
    "implicitDependencies": [
      "mas-salud-backend"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "apps/mas-salud-backend-e2e/jest.config.ts",
          "passWithNoTests": true
        },
        "dependsOn": [
          "mas-salud-backend:build"
        ]
      }
    }
  }
}
